{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash",
      "WebFetch",
      "WebSearch",
      "mcp__*",
      "Task",
      "Read",
      "Glob",
      "Grep",
      "TodoWrite",
      "NotebookEdit"
    ]
  },
  "enableAllProjectMcpServers": true,
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "180000"
  },
  "plansDirectory": "docs/plans",
  "spinnerVerbs": {
    "mode": "append",
    "verbs": ["Hexing"]
  },
  "spinnerTipsEnabled": true,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "language": "english",
  "companyAnnouncements": [
    "Lock and Load. Rip and Tear."
  ]
}
